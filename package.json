{
  "name": "fluxcd-ai-homelab",
  "version": "1.0.0",
  "description": "Flux GitOps cluster bootstrap CLI with interactive TUI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fluxcd-ai-homelab": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test:validate": "tsx --test tests/validate.ts",
    "test:integration": "tsx --test tests/integration.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
