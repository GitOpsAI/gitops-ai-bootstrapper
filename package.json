{
  "name": "gitops-ai",
  "version": "1.2.3",
  "description": "Flux GitOps infrastructure management CLI with interactive TUI",
  "keywords": [
    "gitops",
    "flux",
    "fluxcd",
    "kubernetes",
    "k8s",
    "infrastructure",
    "iac",
    "cli",
    "bootstrap",
    "template-sync",
    "devops",
    "platform-engineering",
    "cd",
    "continuous-delivery",
    "homelab"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GitOpsAI/gitops-ai-bootstrapper.git"
  },
  "homepage": "https://gitops-ai.vercel.app/",
  "author": "everythings-gonna-be-alright",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gitops-ai": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test:validate": "tsx --test tests/validate.ts",
    "test:sync": "tsx --test tests/template-sync.test.ts",
    "test:pod-console": "tsx --test tests/pod-console.test.ts",
    "test:integration": "tsx --test tests/integration.test.ts && npm run test:pod-console",
    "test:template-upgrade": "tsx --test tests/template-upgrade.test.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@kubernetes/client-node": "^1.4.0",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
